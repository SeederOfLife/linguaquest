     questions:[
      {q:"Avec 5% par an sur 1000€, combien as-tu après 20 ans en intérêt composé ?", choices:["1 000 €","2 000 €","2 653 €","5 000 €"], correct:2, explain:"1000 × (1.05)^20 = 2 653€. Presque 3× la mise initiale, juste grâce au temps !"},
