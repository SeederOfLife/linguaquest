    de:{title:'Zinseszins', difficulty:'Anfänger',
     intro:"Albert Einstein soll gesagt haben: 'Der Zinseszins ist das achte Weltwunder.'",
     questions:[
      {q:"Mit 5% pro Jahr auf 1000€, wie viel hast du nach 20 Jahren?", choices:["1.000€","2.000€","2.653€","5.000€"], correct:2, explain:"1000 × (1,05)^20 = 2.653€. Fast das 3-Fache der Anfangsinvestition, nur dank der Zeit!"},
